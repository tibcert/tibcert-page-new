---

<Layout
    title="Response Hub"
    description="A volunteer based community platform under TibCERT."
>
    <!-- Hero -->
    <section class="relative py-24 overflow-hidden">
        <div class="absolute inset-0 bg-brand-red/[0.02] -z-10"></div>
        <div class="container mx-auto px-4 text-center relative">
            <!-- Technical Accent -->
            <div
                class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-12 bg-gradient-to-b from-brand-red/50 to-transparent"
            >
            </div>

            <span
                class="inline-block font-mono text-[10px] text-brand-red tracking-[0.4em] mb-4 uppercase"
            >
                COMMUNITY_DEFENSE_NETWORK // HUB_INDEX
            </span>

            <div class="relative inline-block px-12 py-4">
                <div
                    class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-brand-red/40"
                >
                </div>
                <div
                    class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-brand-red/40"
                >
                </div>
                <div
                    class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-brand-red/40"
                >
                </div>
                <div
                    class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-brand-red/40"
                >
                </div>

                <h1
                    class="text-5xl md:text-7xl font-black text-white tracking-tighter uppercase italic"
                >
                    Response <span class="text-brand-red">Hub</span>
                </h1>
            </div>

            <p
                class="text-sm font-mono text-brand-muted mt-8 uppercase tracking-[0.2em] max-w-2xl mx-auto flex items-center justify-center gap-4"
            >
                <span class="w-2 h-2 bg-brand-red/20 rotate-45"></span>
                LEARN. SHARE. NETWORK. SUPPORT.
                <span class="w-2 h-2 bg-brand-red/20 rotate-45"></span>
            </p>
        </div>
    </section>

    <!-- Intro Sections -->
    <section class="py-16 relative overflow-visible">
        <div class="container mx-auto px-4">
            <div
                class="grid grid-cols-1 lg:grid-cols-3 gap-1 bg-white/[0.03] border border-white/5 relative"
            >
                <!-- Card 01: What is a Response Hub? -->
                <div class="bg-brand-void relative p-8 group overflow-hidden">
                    <!-- Tech Accents -->
                    <div
                        class="absolute top-0 right-0 w-16 h-16 bg-brand-red/[0.02] -rotate-45 translate-x-8 -translate-y-8"
                    >
                    </div>

                    <div class="mb-8 flex items-end justify-between">
                        <div>
                            <span
                                class="font-mono text-[9px] text-brand-red tracking-widest block mb-1"
                                >DATA_NODE_01</span
                            >
                            <h2
                                class="text-xl font-black text-white uppercase tracking-tight"
                            >
                                Definition
                            </h2>
                        </div>
                        <div
                            class="w-10 h-10 border border-white/10 flex items-center justify-center text-brand-red group-hover:border-brand-red/40 transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                                ></path><polyline points="9 22 9 12 15 12 15 22"
                                ></polyline></svg
                            >
                        </div>
                    </div>

                    <h3 class="text-lg font-bold text-white mb-4 italic">
                        What is a Response Hub?
                    </h3>
                    <p
                        class="text-sm text-brand-muted leading-relaxed font-light"
                    >
                        A volunteer based community platform under TibCERT,
                        built on the structure of Learn, Share, Network and
                        Support. An opportunity to address key tech challenges
                        in our Tibetan community through collaborative
                        brainstorming and implementation of solutions.
                    </p>
                </div>

                <!-- Card 02: Who can join us? -->
                <div class="bg-brand-void relative p-8 group overflow-hidden">
                    <div class="mb-8 flex items-end justify-between">
                        <div>
                            <span
                                class="font-mono text-[9px] text-brand-red tracking-widest block mb-1"
                                >DATA_NODE_02</span
                            >
                            <h2
                                class="text-xl font-black text-white uppercase tracking-tight"
                            >
                                Eligibility
                            </h2>
                        </div>
                        <div
                            class="w-10 h-10 border border-white/10 flex items-center justify-center text-brand-red group-hover:border-brand-red/40 transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
                                ></path><circle cx="9" cy="7" r="4"
                                ></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"
                                ></path><path d="M16 3.13a4 4 0 0 1 0 7.75"
                                ></path></svg
                            >
                        </div>
                    </div>

                    <h3 class="text-lg font-bold text-white mb-4 italic">
                        Who can join us?
                    </h3>
                    <p
                        class="text-sm text-brand-muted leading-relaxed font-light"
                    >
                        We believe that varying skills and backgrounds are
                        integral to a successful team. Technical expertise is
                        secondary to a passion for learning and contributing. We
                        welcome anyone eager to share ideas and work
                        collaboratively for the community.
                    </p>
                </div>

                <!-- Card 03: What is a Meetup? -->
                <div class="bg-brand-void relative p-8 group overflow-hidden">
                    <!-- Character Pop-out (Cyber Look) -->
                    <div
                        class="absolute -bottom-12 -right-12 w-48 opacity-10 grayscale group-hover:grayscale-0 group-hover:opacity-20 transition-all duration-1000"
                    >
                        <img
                            src="/images/character.png"
                            alt=""
                            class="w-full h-auto"
                        />
                    </div>

                    <div
                        class="mb-8 flex items-end justify-between relative z-10"
                    >
                        <div>
                            <span
                                class="font-mono text-[9px] text-brand-red tracking-widest block mb-1"
                                >DATA_NODE_03</span
                            >
                            <h2
                                class="text-xl font-black text-white uppercase tracking-tight"
                            >
                                Engagement
                            </h2>
                        </div>
                        <div
                            class="w-10 h-10 border border-white/10 flex items-center justify-center text-brand-red group-hover:border-brand-red/40 transition-colors"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M17 6.1H3"></path><path d="M21 12.1H3"
                                ></path><path d="M15.1 18.1H3"></path></svg
                            >
                        </div>
                    </div>

                    <h3 class="text-lg font-bold text-white mb-4 italic">
                        What is a Meetup?
                    </h3>
                    <div
                        class="space-y-4 text-brand-muted leading-relaxed relative z-10"
                    >
                        <p class="text-sm font-light">
                            A casual 2-hour monthly gathering where hub members
                            discuss community digital security challenges and
                            brainstorm creative solutions.
                        </p>
                        <div
                            class="grid grid-cols-1 gap-2 border-t border-white/5 pt-4 font-mono text-[9px] uppercase tracking-widest"
                        >
                            <div class="flex items-center gap-3">
                                <span class="w-1.5 h-1.5 bg-brand-red/40"
                                ></span>
                                <span>LOC_CORE: CAFES / TAI_OFFICE</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="w-1.5 h-1.5 bg-brand-red/40"
                                ></span>
                                <span>TIME_RECUR: MONTHLY_CONSENSUS</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section
        class="py-24 relative overflow-hidden bg-brand-red/[0.02] border-y border-white/5"
    >
        <div
            class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-brand-red/20 to-transparent"
        >
        </div>
        <div class="container mx-auto px-4 text-center max-w-4xl relative">
            <span
                class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-6 block uppercase"
                >SECURE_NETWORK_NODE // ACCESS_POINT</span
            >

            <h2
                class="text-4xl font-black text-white mb-6 uppercase tracking-tighter italic"
            >
                Join the <span class="text-brand-red">Movement</span>
            </h2>
            <p
                class="text-base text-brand-muted mb-10 leading-relaxed font-light max-w-2xl mx-auto"
            >
                Seeking individuals dedicated to community digital defense. Our
                monthly gatherings focus on technical exchange, brainstorming,
                and collaborative implementation of security solutions.
            </p>

            <a
                href="/contact"
                class="inline-block bg-brand-red hover:bg-[#d13d25] text-white font-mono text-xs uppercase tracking-[0.2em] px-10 py-4 rounded-sm transition-all shadow-xl shadow-brand-red/10 border border-brand-red/20"
            >
                [ ESTABLISH_CONNECTION ]
            </a>
        </div>
    </section>

    <!-- Regional Hubs -->
    <section class="py-24">
        <div class="container mx-auto px-4">
            <!-- Tabs -->
            <div
                class="flex flex-wrap gap-2 mb-16 justify-center"
                id="hub-tabs"
            >
                {
                    hubs.map((hub, index) => (
                        <button
                            class={`hub-tab-btn px-8 py-3 font-mono text-[10px] uppercase tracking-[0.2em] border transition-all ${index === 0 ? "active bg-brand-red border-brand-red text-white" : "bg-brand-void text-brand-muted border-white/10 hover:border-brand-red/30"}`}
                            data-target={hub.id}
                        >
                            {hub.name}
                        </button>
                    ))
                }
            </div>

            <!-- Content Area: Dharamshala -->
            <div
                id="dharamshala"
                class="hub-content animate-in fade-in slide-in-from-bottom-4 duration-500"
            >
                <div class="text-center mb-16 relative">
                    <span
                        class="font-mono text-[9px] text-brand-red tracking-widest block mb-2 uppercase"
                        >HUB_STATUS: ACTIVE // DH_01</span
                    >
                    <h2
                        class="text-3xl font-black text-white mb-4 uppercase tracking-tight italic"
                    >
                        Dharamshala Response Hub
                    </h2>
                    <p
                        class="text-sm text-brand-muted max-w-2xl mx-auto font-light leading-relaxed"
                    >
                        Established: OCT_16_2020. Core infrastructure for
                        localized security response and technical capacity
                        building within the central Tibetan community hub.
                    </p>
                </div>

                <!-- Members Grid -->
                <div class="mb-20">
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 border border-white/5"
                    >
                        {
                            dharamshalaMembers.map((member) => (
                                <div class="bg-brand-void group flex items-stretch relative overflow-hidden transition-all duration-300 h-24">
                                    <!-- Hover Background Accent -->
                                    <div class="absolute inset-0 bg-brand-red/[0.01] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                    
                                    <!-- Left: Profile Thumbnail -->
                                    <div class="relative w-24 shrink-0 overflow-hidden bg-brand-void/80 grayscale group-hover:grayscale-0 transition-all duration-700 border-r border-white/5">
                                        <img
                                            src={member.image}
                                            alt={member.name}
                                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                        />
                                        <div class="absolute inset-0 bg-brand-red/10 opacity-0 group-hover:opacity-100 transition-opacity" />
                                    </div>

                                    <!-- Right: Personal Information -->
                                    <div class="flex-grow min-w-0 relative z-10 p-4 flex flex-col justify-center">
                                        <div class="flex items-center gap-2 mb-1">
                                            <div class="w-1 h-1 bg-brand-red/40"></div>
                                            <span class="font-mono text-[7px] text-brand-red tracking-widest uppercase opacity-60">
                                                Verified_Node
                                            </span>
                                        </div>
                                        <h4 class="text-sm font-black text-white group-hover:text-brand-red transition-colors uppercase tracking-tight leading-none mb-1 truncate">
                                            {member.name}
                                        </h4>
                                        <div class="text-[9px] text-brand-muted font-mono uppercase tracking-widest leading-tight mb-2 truncate">
                                            {member.role || "Team Member"}
                                        </div>
                                        <div class="pt-1 border-t border-white/5">
                                            <span class="text-[8px] text-brand-text font-bold uppercase tracking-widest block truncate opacity-70">
                                                {member.org}
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <!-- Technical Border Corner (Interactive) -->
                                    <div class="absolute top-0 left-0 w-1 h-1 border-t border-l border-white/10 group-hover:border-brand-red/40 transition-colors pointer-events-none z-20"></div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Content Area: Bylakuppe (Placeholder) -->
    <div
        id="bylakuppe"
        class="hub-content hidden animate-in fade-in slide-in-from-bottom-4 duration-500"
    >
        <div
            class="text-center py-20 bg-brand-surface/30 rounded-2xl border border-white/5 border-dashed"
        >
            <h2 class="text-2xl font-bold text-white mb-4">
                Bylakuppe Response Hub
            </h2>
            <p class="text-brand-muted">
                Content for Bylakuppe is currently being updated. Please check
                back soon.
            </p>
        </div>
    </div>

    <!-- Content Area: Mundgod (Placeholder) -->
    <div
        id="mundgod"
        class="hub-content hidden animate-in fade-in slide-in-from-bottom-4 duration-500"
    >
        <div
            class="text-center py-20 bg-brand-surface/30 rounded-2xl border border-white/5 border-dashed"
        >
            <h2 class="text-2xl font-bold text-white mb-4">
                Mundgod Response Hub
            </h2>
            <p class="text-brand-muted">
                Content for Mundgod is currently being updated. Please check
                back soon.
            </p>
        </div>
    </div>
    <!-- Impact & Activities (Standalone) -->
    <section class="py-24 bg-brand-void relative overflow-hidden">
        <!-- Background Grid -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_80%)]"></div>

        <div class="container mx-auto px-4 relative">
            <div class="mb-16">
                <span class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-2 block uppercase">MISSION_LOG // IMPACT_ASSESSMENT</span>
                <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tight italic flex items-center gap-4">
                    Impact & Activities
                    <div class="h-1 flex-grow bg-white/5 relative">
                        <div class="absolute inset-y-0 left-0 w-32 bg-brand-red/40"></div>
                    </div>
                </h2>
            </div>

            <div class="grid grid-cols-1 gap-px bg-white/5 border border-white/5">
                {
                    projects.map((project, index) => (
                        <div class="group bg-brand-void relative overflow-hidden">
                            <!-- Technical Border Accents -->
                            <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-white/20 group-hover:border-brand-red/40 transition-colors"></div>
                            <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-white/20 group-hover:border-brand-red/40 transition-colors"></div>
                            
                            <div class="p-8 md:p-12 flex flex-col md:flex-row gap-12 relative z-10 hover:bg-brand-red/[0.01] transition-colors">
                                <div class="flex-shrink-0">
                                    <span class="font-mono text-4xl font-black text-white/5 group-hover:text-brand-red/10 transition-colors">
                                        ID_{String(index + 1).padStart(2, '0')}
                                    </span>
                                </div>

                                <div class="flex-grow">
                                    <div class="flex items-center gap-4 mb-4">
                                        <div class="h-2 w-2 bg-brand-red rotate-45"></div>
                                        <h3 class="text-2xl font-black text-white uppercase tracking-tight group-hover:text-brand-red transition-colors">
                                            {project.title}
                                        </h3>
                                    </div>
                                    
                                    <p class="text-brand-muted mb-8 leading-relaxed font-light max-w-3xl">
                                        {project.description}
                                    </p>
                                    
                                    {project.details && (
                                        <div class="mb-8 p-4 bg-white/[0.02] border-l-2 border-brand-red/20">
                                            <span class="font-mono text-[9px] text-brand-red tracking-widest block mb-2 uppercase opacity-60">Technical_Specifications</span>
                                            <p class="text-sm text-brand-muted/80 font-light">
                                                {project.details}
                                            </p>
                                        </div>
                                    )}

                                    <div class="flex items-center gap-6">
                                        <a
                                            href={project.link}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center gap-3 font-mono text-[10px] text-brand-red uppercase tracking-[0.2em] group/link"
                                        >
                                            <span class="transition-transform group-hover/link:translate-x-1">[ ACCESS_DATA ]</span>
                                            <div class="h-px w-8 bg-brand-red/40 group-hover/link:w-12 transition-all"></div>
                                        </a>
                                        <span class="text-[9px] font-mono text-white/10 tracking-[0.4em] uppercase hidden md:block">
                                            LINK_HASH: {Math.random().toString(36).substring(7).toUpperCase()}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</Layout>

<script>
    document.addEventListener("astro:page-load", () => {
        setupTabs();
    });

    // Fallback for initial load if not using View Transitions or standard load
    // Just in case astro:page-load isn't firing (requires View Transitions router), we also run on DOMContentLoaded
    document.addEventListener("DOMContentLoaded", setupTabs);

    function setupTabs() {
        const buttons = document.querySelectorAll(".hub-tab-btn");
        const contents = document.querySelectorAll(".hub-content");

        if (!buttons.length) return;

        buttons.forEach((button) => {
            button.addEventListener("click", () => {
                // Remove active class from all buttons
                buttons.forEach((btn) => {
                    btn.classList.remove("bg-brand-red", "border-brand-red", "text-white");
                    btn.classList.add(
                        "bg-brand-void",
                        "text-brand-muted",
                        "border-white/10",
                    );
                });

                // Add active class to clicked button
                button.classList.remove(
                    "bg-brand-void",
                    "text-brand-muted",
                    "border-white/10",
                );
                button.classList.add("bg-brand-red", "border-brand-red", "text-white");

                // Toggle content
                const targetId = button.getAttribute("data-target");
                contents.forEach((content) => {
                    if (content.id === targetId) {
                        content.classList.remove("hidden");
                    } else {
                        content.classList.add("hidden");
                    }
                });
            });
        });
    }
