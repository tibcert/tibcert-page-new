---
import Layout from "../layouts/Layout.astro";

const services = [
    {
        id: "SRV_01",
        title: "Digital Forensics",
        description: "Post-incident analysis to determine the origin, scope, and impact of digital security breaches.",
        icon: "🔍"
    },
    {
        id: "SRV_02",
        title: "Threat Monitoring",
        description: "Real-time surveillance of targeted malware and phishing campaigns attacking the Tibetan community.",
        icon: "📡"
    },
    {
        id: "SRV_03",
        title: "Response Coordination",
        description: "Unified command during large-scale digital attacks affecting multiple organizations.",
        icon: "🛡️"
    },
    {
        id: "SRV_04",
        title: "Vulnerability Scanning",
        description: "Automated and manual assessments of organization infra to identify critical security gaps.",
        icon: "⚙️"
    },
    {
        id: "SRV_05",
        title: "Security Hardening",
        description: "Implementation of multi-layered defense strategies for identities, networks, and end-user devices.",
        icon: "🔐"
    },
    {
        id: "SRV_06",
        title: "Incident Triage",
        description: "Immediate classification and resource allocation for incoming digital security alerts.",
        icon: "🚨"
    }
];
---

<Layout title="Services | TIBCERT">
    <main class="pt-32 pb-24 relative overflow-hidden">
        <!-- Background Grid -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_90%)] -z-10"></div>

        <div class="container mx-auto px-4">
            <!-- Header Section -->
            <div class="max-w-4xl mb-24 reveal relative">
                <!-- Technical Brackets -->
                <div class="absolute -top-8 -left-8 w-12 h-12 border-t border-l border-brand-red/20 uppercase"></div>
                
                <span class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-4 block uppercase opacity-60">CATALOG_SYNC // SERVICE_DIRECTIVES</span>
                <h1 class="text-5xl md:text-8xl font-black mb-6 text-brand-text leading-none uppercase tracking-tighter italic">
                    Defense <span class="text-brand-red">Protocols</span>
                </h1>
                <p class="text-brand-muted text-base font-light leading-relaxed max-w-xl">
                    Specialized technical operations and digital defense strategies established to protect Tibetan civil society.
                </p>
            </div>

            <!-- Services Grid (Tech-Spec Style) -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-text/5 border border-brand-text/5">
                {
                    services.map((service) => (
                        <div class="bg-brand-void group relative overflow-hidden">
                            <!-- Technical Border Accents -->
                            <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                            <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>

                            <div class="p-8 md:p-12 hover:bg-brand-red/[0.01] transition-all duration-500 h-full flex flex-col relative">
                                <div class="flex items-center justify-between mb-10">
                                    <span class="font-mono text-[9px] text-brand-red tracking-[0.3em] font-bold uppercase opacity-60">
                                        {service.id}
                                    </span>
                                    <div class="text-2xl opacity-40 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500">
                                        {service.icon}
                                    </div>
                                </div>
                                
                                <h3 class="text-2xl font-black text-brand-text mb-4 group-hover:text-brand-red transition-colors leading-tight uppercase tracking-tight italic">
                                    {service.title}
                                </h3>
                                <p class="text-brand-muted text-sm leading-relaxed mb-12 flex-grow font-light">
                                    {service.description}
                                </p>
                                
                                <div class="mt-auto pt-6 border-t border-brand-text/5 flex items-center justify-between">
                                    <span class="font-mono text-[8px] uppercase text-brand-muted/30 tracking-[0.3em]">SEC_LEVEL: ALPHA</span>
                                    <div class="flex gap-1">
                                        <div class="w-1 h-1 bg-brand-red/40"></div>
                                        <div class="w-1 h-1 bg-brand-red/40"></div>
                                        <div class="w-1 h-1 bg-brand-red/40"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>

            <!-- Call to Action -->
            <div class="mt-24 p-12 bg-brand-red border border-brand-red/20 relative reveal overflow-hidden group">
                <div class="absolute inset-0 bg-brand-void/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                <!-- Scanning line effect -->
                <div class="absolute inset-0 bg-[linear-gradient(to_bottom,transparent_0%,rgba(255,255,255,0.05)_50%,transparent_100%)] bg-[length:100%_200%] animate-scan pointer-events-none"></div>
                
                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12 text-center md:text-left">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-black text-white mb-4 uppercase tracking-tighter italic">Initiate Defense Request</h2>
                        <p class="text-brand-text/80 font-light max-w-xl">Request professional digital security assistance for your organization. Our team monitors channels 24/7.</p>
                    </div>
                    <a
                        href="/contact"
                        class="bg-white text-brand-red font-mono text-xs tracking-[0.3em] px-10 py-5 hover:gap-8 gap-4 flex items-center transition-all uppercase shadow-2xl shadow-black/20"
                    >
                        [ CONTACT_OPERATIONS ] <span>&rarr;</span>
                    </a>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.revealed {
        opacity: 1;
        transform: translateY(0);
    }
</style>
