---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
    return date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
};
---

<Layout title={`${post.data.title} | Blog | TIBCERT`}>
    <main class="pt-32 pb-24 relative overflow-hidden">
        <!-- Premium Radial Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] bg-[radial-gradient(circle_at_50%_-20%,rgba(220,38,38,0.15),transparent_70%)] pointer-events-none"></div>
        <article class="container mx-auto px-4 max-w-4xl">
            <!-- Breadcrumbs -->
            <div
                class="flex items-center gap-2 font-mono text-[9px] text-brand-muted uppercase tracking-[0.2em] mb-12 reveal"
            >
                <a href="/" class="hover:text-brand-red transition-colors">[ root ]</a>
                <span class="opacity-20">//</span>
                <a href="/blog" class="hover:text-brand-red transition-colors">[ log_index ]</a>
                <span class="opacity-20">//</span>
                <span class="text-brand-red">{post.data.category}</span>
            </div>

            <!-- Title & Metadata -->
            <div class="mb-16 reveal relative">
                <!-- Header Decorative line -->
                <div class="absolute -top-4 left-0 w-24 h-px bg-brand-red/40"></div>

                <div class="flex flex-wrap items-center gap-6 mb-8">
                    <span
                        class="px-3 py-1 bg-brand-red border border-brand-red/20 text-white font-mono text-[9px] font-black tracking-[0.3em] uppercase"
                    >
                        {post.data.category}
                    </span>
                    <div class="flex items-center gap-3">
                        <span class="w-2 h-2 bg-brand-red/20 rotate-45"></span>
                        <time
                            class="text-brand-muted font-mono text-[10px] tracking-widest uppercase opacity-60"
                        >
                            {formatDate(post.data.pubDate)}
                        </time>
                    </div>
                </div>

                <h1
                    class="text-4xl md:text-7xl font-black text-brand-text mb-12 leading-[1.05] uppercase tracking-tighter italic"
                >
                    {post.data.title}
                </h1>

                <div
                    class="flex flex-col sm:flex-row sm:items-center gap-8 p-8 bg-brand-void border border-brand-text/5 relative overflow-hidden"
                >
                    <!-- Background Accent -->
                    <div class="absolute top-0 right-0 w-16 h-16 bg-brand-red/[0.02] -rotate-45 translate-x-8 -translate-y-8"></div>
                    
                    <div class="flex items-center gap-6 relative z-10">
                        <div
                            class="w-16 h-16 bg-brand-red/10 border border-brand-red/30 flex items-center justify-center font-mono font-black text-2xl text-brand-red uppercase"
                            style="clip-path: polygon(15% 0, 100% 0, 100% 85%, 85% 100%, 0 100%, 0 15%);"
                        >
                            {post.data.author.charAt(0)}
                        </div>
                        <div>
                            <span class="font-mono text-[8px] text-brand-red tracking-[0.4em] block mb-1 uppercase opacity-60">AUTHOR_ID</span>
                            <div class="text-brand-text font-black uppercase tracking-tight text-xl italic leading-none">
                                {post.data.author}
                            </div>
                            <div class="text-brand-muted font-mono text-[9px] uppercase tracking-widest mt-1 opacity-40">
                                ORG: TIBCERT_EDITORIAL
                            </div>
                        </div>
                    </div>
                    
                    <div class="sm:ml-auto flex flex-wrap gap-2 relative z-10">
                        {
                            post.data.tags?.map((tag) => (
                                <span class="px-3 py-1 border border-brand-text/10 font-mono text-[9px] text-brand-muted uppercase tracking-widest hover:border-brand-red/40 transition-colors">
                                    #{tag}
                                </span>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Featured Image -->
            {
                post.data.image && (
                    <div class="mb-16 relative group reveal">
                        <!-- Corner Brackets -->
                        <div class="absolute -top-4 -left-4 w-8 h-8 border-t-2 border-l-2 border-brand-red/40 z-20 transition-all group-hover:scale-110"></div>
                        <div class="absolute -bottom-4 -right-4 w-8 h-8 border-b-2 border-r-2 border-brand-red/40 z-20 transition-all group-hover:scale-110"></div>
                        
                        <div class="overflow-hidden bg-brand-void border border-brand-text/10 group-hover:border-brand-red/20 transition-colors">
                            <Image
                                src={post.data.image}
                                alt={post.data.title}
                                width={1200}
                                height={675}
                                class="w-full h-auto object-cover opacity-80 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105"
                            />
                        </div>
                    </div>
                )
            }

            <!-- Content -->
            <div
                class="prose prose-invert prose-brand max-w-none
                prose-headings:font-black prose-headings:tracking-tight prose-headings:text-brand-text
                prose-h1:text-4xl prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:border-b prose-h2:border-brand-text/5 prose-h2:pb-4
                prose-p:text-brand-muted prose-p:text-lg prose-p:leading-relaxed prose-p:mb-8
                prose-strong:text-brand-text prose-strong:font-bold
                prose-ul:list-disc prose-ul:pl-6 prose-li:text-brand-muted prose-li:mb-2
                prose-blockquote:border-l-4 prose-blockquote:border-brand-red prose-blockquote:bg-brand-red/5 prose-blockquote:p-8 prose-blockquote:rounded-r-2xl prose-blockquote:italic prose-blockquote:text-xl
                reveal"
            >
                <Content />
            </div>

            <!-- Footer -->
            <div
                class="mt-24 pt-12 border-t border-brand-text/5 flex flex-wrap items-center justify-between gap-12 reveal"
            >
                <div class="flex items-center gap-6">
                    <span
                        class="font-mono text-[10px] text-brand-muted uppercase tracking-[0.3em] opacity-60"
                        >Share_log:</span
                    >
                    <div class="flex gap-4">
                        {
                            ["Twitter", "LinkedIn", "Copy Link"].map(
                                (platform) => (
                                    <button class="font-mono text-[9px] text-brand-text uppercase tracking-[0.2em] border border-brand-text/10 px-4 py-2 hover:bg-brand-red hover:border-brand-red transition-all">
                                        {platform}
                                    </button>
                                ),
                            )
                        }
                    </div>
                </div>

                <a
                    href="/blog"
                    class="font-mono text-[10px] text-brand-red uppercase tracking-[0.3em] flex items-center gap-4 group/back"
                >
                    <span class="transition-transform group-hover/back:-translate-x-1">&larr; [ RETURN_TO_LOG_INDEX ]</span>
                </a>
            </div>
        </article>
    </main>
</Layout>
