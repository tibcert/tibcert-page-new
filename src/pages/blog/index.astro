---
import { getCollection } from 'astro:content';
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
    return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: '2-digit'
    }).toUpperCase();
};
---

<Layout title="Blog | TIBCERT">
    <main class="pt-32 pb-24">
        <div class="container mx-auto px-4">
            <!-- Header Section -->
            <div class="max-w-4xl mb-24 reveal relative">
                <!-- Technical Brackets -->
                <div class="absolute -top-8 -left-8 w-12 h-12 border-t border-l border-brand-red/20 uppercase"></div>
                
                <span class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-4 block uppercase opacity-60">TRANS_LOG // NEWS_FEED</span>
                <h1 class="text-5xl md:text-8xl font-black mb-6 text-brand-text leading-none uppercase tracking-tighter italic">
                    News & <span class="text-brand-red">Insights</span>
                </h1>
                <p class="text-brand-muted text-base font-light leading-relaxed max-w-xl">
                    Technical directives, community intelligence, and system updates established under coordinated security protocols.
                </p>
            </div>

            <!-- Blog Post Grid (Tech-Spec Style) -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-text/5 border border-brand-text/5">
                {sortedPosts.map((post, index) => (
                    <a href={`/blog/${post.slug}`} class="block group h-full reveal bg-brand-void relative overflow-hidden">
                        <!-- Technical Border Accents -->
                        <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>

                        <article class="p-8 hover:bg-brand-red/[0.01] transition-all duration-500 h-full flex flex-col relative">
                            <div class="relative z-10 flex flex-col h-full">
                                <div class="flex items-center justify-between mb-8">
                                    <div class="flex flex-col">
                                        <span class="font-mono text-[8px] text-brand-red tracking-[0.3em] mb-1 uppercase opacity-60">LOG_{String(index + 1).padStart(2, '0')}</span>
                                        <span class="font-mono text-[9px] text-brand-red uppercase tracking-widest font-black">
                                            {post.data.category}
                                        </span>
                                    </div>
                                    <time class="font-mono text-[9px] text-brand-muted/40 uppercase tracking-widest text-right">
                                        {formatDate(post.data.pubDate)}
                                    </time>
                                </div>
                                
                                <h3 class="text-2xl font-black text-brand-red mb-4 group-hover:text-brand-red transition-colors leading-tight uppercase tracking-tight italic">
                                    {post.data.title}
                                </h3>
                                
                                <p class="text-brand-muted text-sm leading-relaxed mb-10 flex-grow font-light line-clamp-3">
                                    {post.data.description}
                                </p>
                                
                                <div class="mt-auto flex items-center justify-between">
                                    <span class="font-mono text-[10px] text-brand-red uppercase tracking-[0.2em]">
                                        [ READ_FULL_LOG ]
                                    </span>
                                    <div class="h-px flex-grow mx-4 bg-brand-text/5 group-hover:bg-brand-red/20 transition-colors"></div>
                                </div>
                            </div>
                        </article>
                    </a>
                ))}
            </div>
        </div>
    </main>
</Layout>
