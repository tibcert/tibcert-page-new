---
// GeminiChat.astro
const GEMINI_API_KEY = import.meta.env.GEMINI_API_KEY || "";
---

<div
    id="gemini-chat-container"
    class="fixed bottom-6 right-6 z-[200] font-sans"
    data-api-key={GEMINI_API_KEY}
>
    <!-- Chat Toggle Button -->
    <button
        id="chat-toggle"
        class="w-16 h-16 rounded-2xl bg-brand-red border-2 border-brand-red/50 flex items-center justify-center cursor-pointer shadow-[0_0_20px_rgba(239,72,44,0.4)] transition-all duration-500 hover:scale-110 hover:shadow-[0_0_30px_rgba(239,72,44,0.6)] group relative overflow-hidden active:scale-95"
        aria-label="Open Chat"
    >
        <div
            class="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"
        >
        </div>
        <span
            class="text-white group-hover:rotate-12 transition-transform duration-300"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="currentColor"
                stroke="none"
                ><path
                    d="M12 2C6.48 2 2 6.48 2 12c0 2.15.68 4.15 1.83 5.79L2 22l4.21-1.83C7.85 21.32 9.85 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2h2v2zm0-4h-2V7h2v5z"
                ></path></svg
            >
        </span>
        <!-- Cyber pulse ring -->
        <span
            class="absolute inset-0 rounded-2xl border-2 border-white/30 animate-ping opacity-20 scale-75"
        ></span>
    </button>

    <!-- Chat Window -->
    <div
        id="chat-window"
        class="absolute bottom-24 right-0 w-[380px] max-w-[calc(100vw-48px)] h-[550px] bg-brand-void/80 backdrop-blur-xl border-2 border-brand-red/30 rounded-3xl overflow-hidden flex flex-col shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-all duration-500 transform scale-90 opacity-0 pointer-events-none translate-y-8 origin-bottom-right"
    >
        <!-- Header with Gradient and Gloss -->
        <div
            class="bg-gradient-to-r from-brand-red via-brand-red to-brand-maroon p-5 flex justify-between items-center text-white relative"
        >
            <div
                class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.1)_50%,transparent_75%)] bg-[length:250%_250%] animate-gloss pointer-events-none"
            >
            </div>
            <div class="flex items-center gap-3 relative z-10">
                <div
                    class="w-10 h-10 rounded-xl bg-white/10 backdrop-blur-md flex items-center justify-center border border-white/20 shadow-inner"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        stroke="none"
                        ><path
                            d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z"
                        ></path></svg
                    >
                </div>
                <div class="flex flex-col">
                    <h3
                        class="font-bold text-base m-0 leading-none tracking-tight"
                    >
                        TIBCERT AI
                    </h3>
                    <div class="flex items-center gap-1.5 mt-1">
                        <span
                            class="w-2 h-2 rounded-full bg-green-400 animate-pulse"
                        ></span>
                        <span
                            class="text-[10px] opacity-90 uppercase tracking-[0.2em] font-mono font-bold"
                            >Protocol Active</span
                        >
                    </div>
                </div>
            </div>
            <button
                id="close-chat"
                class="w-8 h-8 flex items-center justify-center hover:bg-white/20 rounded-full transition-all cursor-pointer relative z-10 active:scale-90"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M18 6 6 18"></path><path d="m6 6 12 12"
                    ></path></svg
                >
            </button>
        </div>

        <!-- Messages Container -->
        <div
            id="chat-messages"
            class="flex-grow overflow-y-auto p-4 space-y-4 scrollbar-thin scrollbar-thumb-brand-red/20 scrollbar-track-transparent"
        >
            <!-- Welcome Message -->
            <div class="flex gap-2 max-w-[85%] animate-fade-in">
                <div
                    class="w-8 h-8 rounded-full bg-brand-surface border border-brand-red/20 flex-shrink-0 flex items-center justify-center text-brand-red"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M12 8V4H8"></path><rect
                            width="16"
                            height="12"
                            x="4"
                            y="8"
                            rx="2"></rect><path d="M16 8V4h4"></path></svg
                    >
                </div>
                <div
                    class="bg-brand-surface p-3 rounded-2xl rounded-tl-none border border-brand-red/10 text-sm"
                >
                    <p class="m-0">
                        Tashi Delek! How can I help you today with digital
                        security or TIBCERT information?
                    </p>
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-4 border-t border-brand-red/10 bg-brand-surface/30">
            <form id="chat-form" class="flex gap-2">
                <input
                    type="text"
                    id="chat-input"
                    placeholder="Type your message..."
                    class="flex-grow bg-brand-void border border-brand-red/30 rounded-full px-4 py-2 text-sm focus:outline-none focus:border-brand-red focus:ring-1 focus:ring-brand-red transition-all"
                    required
                />
                <button
                    type="submit"
                    class="bg-brand-red text-white w-9 h-9 rounded-full flex items-center justify-center hover:scale-105 active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                    id="send-button"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="m22 2-7 20-4-9-9-4Z"></path><path
                            d="M22 2 11 13"></path></svg
                    >
                </button>
            </form>
            <p class="text-[9px] text-center mt-2 opacity-50 font-mono">
                ENCRYPTED PROTOCOL ACTIVE | VER 1.0.4
            </p>
        </div>

        <!-- Scanline Effect for Window -->
        <div
            class="absolute inset-0 pointer-events-none opacity-[0.03] overflow-hidden rounded-2xl"
        >
            <div
                class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%)] bg-[length:100%_4px] animate-scan"
            >
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes fade-in {
        from {
            opacity: 0;
            transform: translateY(20px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @keyframes gloss {
        0% {
            background-position: -200% 0;
        }
        100% {
            background-position: 200% 0;
        }
    }

    .animate-fade-in {
        animation: fade-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-gloss {
        animation: gloss 3s linear infinite;
    }

    #chat-window.open {
        opacity: 1;
        pointer-events: auto;
        transform: scale(1) translateY(0);
    }

    /* Cyber Loading dots */
    .typing-dot {
        width: 6px;
        height: 6px;
        background: #ef482c;
        border-radius: 50%;
        animation: typing 1.4s infinite ease-in-out;
        box-shadow: 0 0 8px rgba(239, 72, 44, 0.5);
    }
    .typing-dot:nth-child(1) {
        animation-delay: 0s;
    }
    .typing-dot:nth-child(2) {
        animation-delay: 0.2s;
    }
    .typing-dot:nth-child(3) {
        animation-delay: 0.4s;
    }

    @keyframes typing {
        0%,
        80%,
        100% {
            transform: scale(0.6);
            opacity: 0.4;
        }
        40% {
            transform: scale(1.2);
            opacity: 1;
        }
    }

    /* Scanline Animation */
    @keyframes scan {
        from {
            background-position: 0 0;
        }
        to {
            background-position: 0 100%;
        }
    }

    .animate-scan {
        animation: scan 3s linear infinite;
    }

    /* Scrollbar Styling */
    #chat-messages::-webkit-scrollbar {
        width: 5px;
    }
    #chat-messages::-webkit-scrollbar-track {
        background: transparent;
    }
    #chat-messages::-webkit-scrollbar-thumb {
        background: rgba(239, 72, 44, 0.3);
        border-radius: 10px;
    }
    #chat-messages::-webkit-scrollbar-thumb:hover {
        background: rgba(239, 72, 44, 0.5);
    }
</style>

<script>
    import { GoogleGenerativeAI } from "@google/generative-ai";

    // Note: Since GEMINI_API_KEY doesn't have the PUBLIC_ prefix,
    // we pass it from the Astro frontmatter to this script via a data attribute.
    const container = document.getElementById("gemini-chat-container");
    const API_KEY = container?.dataset.apiKey || "";

    // UI Elements
    const toggleBtn = document.getElementById("chat-toggle");
    const chatWindow = document.getElementById("chat-window");
    const closeBtn = document.getElementById("close-chat");
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const input = document.getElementById("chat-input") as HTMLInputElement;
    const messagesContainer = document.getElementById("chat-messages");
    const sendBtn = document.getElementById("send-button") as HTMLButtonElement;

    let chat: any = null;

    // Toggle Window
    toggleBtn?.addEventListener("click", () => {
        chatWindow?.classList.toggle("open");
        if (chatWindow?.classList.contains("open")) {
            input?.focus();
        }
    });

    closeBtn?.addEventListener("click", () => {
        chatWindow?.classList.remove("open");
    });

    // Message Helper
    function appendMessage(text: string, isUser: boolean) {
        if (!messagesContainer) return;

        const messageDiv = document.createElement("div");
        messageDiv.className = `flex gap-2 max-w-[85%] animate-fade-in ${isUser ? "ml-auto flex-row-reverse" : ""}`;

        const iconHtml = isUser
            ? `<div class="w-8 h-8 rounded-full bg-brand-red text-white flex-shrink-0 flex items-center justify-center text-xs font-bold">U</div>`
            : `<div class="w-8 h-8 rounded-full bg-brand-surface border border-brand-red/20 flex-shrink-0 flex items-center justify-center text-brand-red">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M16 8V4h4"/></svg>
        </div>`;

        messageDiv.innerHTML = `
      ${iconHtml}
      <div class="${isUser ? "bg-brand-red text-white" : "bg-brand-surface"} p-3 rounded-2xl ${isUser ? "rounded-tr-none" : "rounded-tl-none"} border border-brand-red/10 text-sm shadow-sm">
        <p class="m-0">${text}</p>
      </div>
    `;

        messagesContainer.appendChild(messageDiv);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function showLoadingIndicator() {
        if (!messagesContainer) return;
        const loadingDiv = document.createElement("div");
        loadingDiv.id = "chat-loading";
        loadingDiv.className = "flex gap-2 max-w-[85%] animate-fade-in";
        loadingDiv.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-brand-surface border border-brand-red/20 flex-shrink-0 flex items-center justify-center text-brand-red">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M16 8V4h4"/></svg>
      </div>
      <div class="bg-brand-surface p-3 rounded-2xl rounded-tl-none border border-brand-red/10 flex items-center gap-1">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    `;
        messagesContainer.appendChild(loadingDiv);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function removeLoadingIndicator() {
        document.getElementById("chat-loading")?.remove();
    }

    // Handle Form Submission
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const message = input.value.trim();
        if (!message) return;

        // UI Feedback
        input.value = "";
        appendMessage(message, true);

        if (!API_KEY) {
            appendMessage(
                "Error: Gemini API Key not configured. Please add GEMINI_API_KEY to your environment variables.",
                false,
            );
            return;
        }

        const modelsToTry = [
            "gemini-1.5-flash",
            "gemini-2.0-flash",
            "gemini-1.5-flash-8b",
            "gemini-pro",
        ];

        let success = false;
        showLoadingIndicator();
        input.disabled = true;
        sendBtn.disabled = true;

        for (const modelName of modelsToTry) {
            try {
                const genAI = new GoogleGenerativeAI(API_KEY);
                const model = genAI.getGenerativeModel({ model: modelName });

                if (!chat || modelsToTry.indexOf(modelName) > 0) {
                    chat = model.startChat({
                        history: [],
                        generationConfig: { maxOutputTokens: 500 },
                    });
                }

                const result = await chat.sendMessage(message);
                const responseText = result.response.text();

                removeLoadingIndicator();
                appendMessage(responseText, false);
                success = true;
                break;
            } catch (error: any) {
                console.warn(`Gemini Error with ${modelName}:`, error);

                if (
                    error.message?.includes("404") ||
                    error.message?.includes("not found")
                ) {
                    chat = null;
                    continue;
                }

                removeLoadingIndicator();
                let errMsg =
                    "Sorry, I encountered an error. Please try again later.";
                if (error.message?.includes("API key")) {
                    errMsg =
                        "API Key Error: Please check if your Google AI Studio key is valid and active.";
                } else if (
                    error.message?.includes("quota") ||
                    error.message?.includes("429")
                ) {
                    errMsg =
                        "Google API Rate Limit Reached: The free tier has limits (e.g., 15 requests per minute). Please wait a moment and try again.";
                } else if (error.message?.includes("Safety")) {
                    errMsg =
                        "The response was blocked due to safety filters. Please try rephrasing.";
                }
                appendMessage(errMsg, false);
                success = true;
                break;
            }
        }

        if (!success) {
            removeLoadingIndicator();
            appendMessage(
                "I'm having trouble connecting to the AI models. Please check your internet or API key status.",
                false,
            );
        }

        input.disabled = false;
        sendBtn.disabled = false;
        input.focus();
    });
</script>
