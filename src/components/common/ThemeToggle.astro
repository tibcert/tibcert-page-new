<button
    id="theme-toggle"
    class="relative inline-flex h-12 w-24 items-center rounded-full bg-[#333333] transition-colors focus:outline-none group overflow-hidden"
    aria-label="Toggle theme"
>
    <!-- Background Track -->
    <div class="absolute inset-0 bg-[#333333]"></div>

    <!-- Right Icon (Moon - visible when handle is on left/Light mode) -->
    <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
        <svg
            class="w-5 h-5 text-white opacity-100 transition-opacity duration-300"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
        >
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
    </div>

    <!-- Left Icon (Sun - typically hidden by handle in light mode, visible in dark mode) -->
    <div class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none">
        <svg
            class="w-5 h-5 text-white opacity-100 transition-opacity duration-300"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <circle cx="12" cy="12" r="4"></circle>
            <path
                d="M12 2v2M12 20v2m-7.07-15.07 1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2m-15.07 7.07 1.41-1.41M19.07 4.93l-1.41-1.41"
            ></path>
        </svg>
    </div>

    <!-- Sliding Handle -->
    <div
        id="theme-toggle-handle"
        class="relative block h-10 w-10 rounded-full bg-white shadow-lg transition-transform duration-500 cubic-bezier-[0.34,1.56,0.64,1] transform translate-x-1 dark:translate-x-13"
    >
    </div>
</button>

<style>
    /* Custom spring easing for the handle */
    #theme-toggle-handle {
        transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    /* Dark mode handle position adjustment */
    :global(.dark) #theme-toggle-handle {
        transform: translateX(
            52px
        ); /* Adjust based on track width (24*4 = 96px, handle 40px, padding 4px -> 96-40-4 = 52) */
    }

    /* Track color in dark mode (optional, keeping it dark as per reference) */
    #theme-toggle {
        background-color: #333333;
    }
</style>

<script>
    function setupThemeToggle() {
        const themeToggleBtn = document.getElementById("theme-toggle");
        if (!themeToggleBtn) return;

        const handle = document.getElementById("theme-toggle-handle");

        const updateTheme = () => {
            const isDark = document.documentElement.classList.contains("dark");
            localStorage.setItem("color-theme", isDark ? "dark" : "light");
        };

        themeToggleBtn.addEventListener("click", () => {
            // Apply a brief stretch effect for better feel
            if (handle) {
                handle.style.transition =
                    "transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)";
            }

            document.documentElement.classList.toggle("dark");
            updateTheme();
        });
    }

    // Support View Transitions
    document.addEventListener("astro:page-load", setupThemeToggle);
    // Initial setup
    setupThemeToggle();
</script>
