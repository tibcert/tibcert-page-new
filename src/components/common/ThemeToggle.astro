<button
    id="theme-toggle"
    class="relative inline-flex h-9 w-16 items-center rounded-full bg-brand-void border border-brand-text/10 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-red/50 group overflow-hidden"
    aria-label="Toggle theme"
>
    <!-- Background Track -->
    <span
        class="absolute inset-0 bg-gradient-to-r from-brand-amber/10 to-brand-red/10 opacity-0 group-hover:opacity-100 transition-opacity"
    ></span>

    <!-- Icons Layer (Fixed) -->
    <div
        class="absolute inset-0 flex items-center justify-between px-2 pointer-events-none"
    >
        <!-- Moon Icon (Left) -->
        <svg
            class="w-4 h-4 text-brand-muted"
            fill="currentColor"
            viewBox="0 0 20 20"
        >
            <path
                d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
            ></path>
        </svg>
        <!-- Sun Icon (Right) -->
        <svg
            class="w-4 h-4 text-brand-amber"
            fill="currentColor"
            viewBox="0 0 20 20"
        >
            <path
                d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
                fill-rule="evenodd"
                clip-rule="evenodd"></path>
        </svg>
    </div>

    <!-- Sliding Handle -->
    <span
        id="theme-toggle-handle"
        class="relative block h-7 w-7 rounded-full bg-brand-text transition-transform duration-500 ease-in-out transform translate-x-1 dark:translate-x-8 flex items-center justify-center overflow-hidden"
    >
        <!-- Icon that changes within the handle -->
        <span
            id="handle-icon-container"
            class="transition-transform duration-500"
        >
            <!-- Dynamically swapped icon will go here or just use CSS to show/hide -->
            <div
                id="handle-sun"
                class="absolute inset-0 flex items-center justify-center opacity-0 dark:opacity-100 transition-opacity"
            >
                <div class="w-4 h-4 bg-brand-red rounded-full"></div>
            </div>
            <div
                id="handle-moon"
                class="absolute inset-0 flex items-center justify-center opacity-100 dark:opacity-0 transition-opacity"
            >
                <div class="w-4 h-4 bg-brand-void rounded-full"></div>
            </div>
        </span>
    </span>
</button>

<script>
    function setupThemeToggle() {
        const themeToggleBtn = document.getElementById("theme-toggle");
        if (!themeToggleBtn) return;

        const updateTheme = () => {
            const isDark = document.documentElement.classList.contains("dark");
            localStorage.setItem("color-theme", isDark ? "dark" : "light");
        };

        themeToggleBtn.addEventListener("click", () => {
            document.documentElement.classList.toggle("dark");
            updateTheme();
        });
    }

    // Support View Transitions
    document.addEventListener("astro:page-load", setupThemeToggle);
    // Initial setup
    setupThemeToggle();
</script>
