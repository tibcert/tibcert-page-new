---
interface Props {
    title: string;
    date: string;
    excerpt: string;
    image?: string;
    category?: string;
    slug: string;
}

const { title, date, excerpt, image, category = "General", slug } = Astro.props;
---

<a href={`/blog/${slug}`} class="block group">
    <article
        class="bg-brand-surface border border-brand-text/5 rounded-lg overflow-hidden hover:border-brand-amber/50 transition-colors h-full flex flex-col"
    >
        {
            image && (
                <div class="h-48 overflow-hidden">
                    <img
                        src={image}
                        alt={title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                </div>
            )
        }
        <div class="p-6 flex-grow flex flex-col">
            <div class="flex items-center gap-2 mb-3 text-xs">
                <span class="text-brand-amber font-medium">{category}</span>
                <span class="text-brand-muted">•</span>
                <time class="text-brand-muted">{date}</time>
            </div>
            <h3
                class="text-xl font-bold text-brand-text mb-2 group-hover:text-brand-amber transition-colors"
            >
                {title}
            </h3>
            <p class="text-sm text-brand-muted flex-grow">
                {excerpt}
            </p>
        </div>
    </article>
</a>
