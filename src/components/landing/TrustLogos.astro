---
import { Image } from "astro:assets";
// Partner logo mapping
const partnerLogos: Record<string, string> = {
    "Citizen Lab": "/images/partners/citizen-lab.svg",
    "Access Now": "/images/partners/access-now.svg",
    "Front Line Defenders": "/images/partners/frontlin-defender.svg",
    "Guardian Project": "/images/partners/guardian-project.svg",
};

const partners = [
    "Citizen Lab",
    "Access Now",
    "Front Line Defenders",
    "Guardian Project",
];
---

<section class="py-16 border-t border-brand-text/5 reveal">
    <div class="container mx-auto px-4 text-center">
        <p
            class="font-mono text-[9px] text-brand-muted/60 uppercase tracking-[0.4em] mb-12 flex items-center justify-center gap-4"
        >
            <span class="h-px w-8 bg-brand-text/5"></span>
            NETWORK_AFFILIATES // TRUST_INDEX
            <span class="h-px w-8 bg-brand-text/5"></span>
        </p>
        <div
            class="flex flex-wrap justify-center items-center gap-12 md:gap-20 opacity-50 grayscale hover:grayscale-0 transition-all duration-500"
        >
            {
                partners.map((partner) => (
                    <div class="text-xl font-bold text-brand-text flex items-center gap-2">
                        {partnerLogos[partner] ? (
                            <Image
                                src={partnerLogos[partner]}
                                alt={partner}
                                width={200}
                                height={
                                    partner === "Citizen Lab" ||
                                    partner === "Front Line Defenders" ||
                                    partner === "Guardian Project"
                                        ? 56
                                        : 40
                                }
                                class:list={[
                                    "w-auto grayscale-0",
                                    partner === "Guardian Project" &&
                                        "brightness-300",
                                ]}
                            />
                        ) : (
                            <>
                                <div class="w-8 h-8 bg-brand-text/10 rounded-full" />
                                {partner}
                            </>
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</section>
