---
import BackgroundGlow from "../common/BackgroundGlow.astro";
import SectionDivider from "../common/SectionDivider.astro";
import { Image } from "astro:assets";

// Using a basic fetch and simple parsing for the RSS feed
// In a production environment, you might use an RSS parser library,
// but for a lightweight Astro component, we can handle it with regex/string-splitting safely.

interface Report {
    title: string;
    link: string;
    date: string;
    thumbnail: string;
    blurb: string;
}

let reports: Report[] = [];

try {
    const response = await fetch("https://blog.tibcert.org/rss.xml");
    const xmlText = await response.text();

    // Simple regex to extract <item> blocks
    const itemMatches = xmlText.match(/<item>([\s\S]*?)<\/item>/g) || [];

    reports = itemMatches.slice(0, 4).map((item) => {
        const title = item.match(/<title><!\[CDATA\[([\s\S]*?)\]\]><\/title>/)?.[1] || 
                      item.match(/<title>([\s\S]*?)<\/title>/)?.[1] || "No Title";
        
        const link = item.match(/<link>([\s\S]*?)<\/link>/)?.[1] || "#";
        const pubDate = item.match(/<pubDate>([\s\S]*?)<\/pubDate>/)?.[1] || "";
        const cover = item.match(/<cover>([\s\S]*?)<\/cover>/)?.[1] || "";
        
        // Construct full image URL
        let thumbnail = "";
        if (cover) {
            thumbnail = cover.startsWith('http') ? cover : `https://blog.tibcert.org${cover.startsWith('/') ? '' : '/'}${cover}`;
        }
        
        // Format the date if possible
        let formattedDate = pubDate;
        try {
            if (pubDate) {
                const date = new Date(pubDate);
                formattedDate = date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: '2-digit'
                }).toUpperCase();
            }
        } catch (e) {
            console.error("Date parsing error", e);
        }

        const description = item.match(/<description><!\[CDATA\[([\s\S]*?)\]\]><\/description>/)?.[1] || 
                            item.match(/<description>([\s\S]*?)<\/description>/)?.[1] || "";
        
        // Simple HTML strip and truncate for blurb
        const blurb = description.replace(/<[^>]*>?/gm, '').trim().split(/\s+/).slice(0, 15).join(' ') + '...';

        return { title, link, date: formattedDate, thumbnail, blurb };
    });
} catch (error) {
    console.error("Error fetching reports feed:", error);
}
---

<section id="reports" class="py-24 bg-brand-void relative overflow-hidden reveal">
    <!-- Sophisticated Background Glows -->
    <BackgroundGlow 
        color="fill-brand-red" 
        size="w-[500px] h-[500px]" 
        opacity="opacity-10" 
        class="-bottom-48 -left-24" 
    />
    <BackgroundGlow 
        color="fill-blue-900" 
        size="w-[400px] h-[400px]" 
        opacity="opacity-5" 
        class="top-12 -right-24" 
    />

    <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16 reveal relative">
            <!-- Technical Brackets -->
            <div class="absolute -top-8 -left-8 w-12 h-12 border-t border-l border-brand-red/20 opacity-60"></div>

            <div class="max-w-2xl">
                <span class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-4 block uppercase opacity-60">EXTERNAL_INTELLIGENCE // DATA_STREAM</span>
                <h3 class="text-3xl md:text-5xl font-black text-brand-text mb-4 uppercase tracking-tight italic">
                    Latest <span class="text-brand-red">Reports</span>
                </h3>
                <SectionDivider class="text-brand-red w-48 mb-6" />
                <p class="text-lg text-brand-muted leading-relaxed">
                    Live feed from the TibCERT community blog, featuring in-depth research and community-driven security updates.
                </p>
            </div>
            <a href="https://blog.tibcert.org" target="_blank" rel="noopener noreferrer" class="text-brand-red font-black text-sm tracking-widest uppercase flex items-center gap-2 group hover:gap-4 transition-all pb-2 border-b-2 border-brand-red/10 hover:border-brand-red">
                VISIT BLOG <span>&rarr;</span>
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-px bg-brand-text/5 border border-brand-text/5">
            {reports.length > 0 ? (
                reports.map((report, index) => (
                    <a href={report.link} target="_blank" rel="noopener noreferrer" class="block group bg-brand-void relative overflow-hidden">
                        <!-- Technical Border Accents -->
                        <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>

                        <article class="relative z-10 p-1 flex flex-col sm:flex-row h-full sm:h-52 hover:bg-brand-red/[0.01] transition-all duration-500">
                            <!-- Image Section -->
                            <div class="w-full sm:w-64 shrink-0 h-44 sm:h-full overflow-hidden relative border-r border-brand-text/5">
                                {report.thumbnail ? (
                                    <Image
                                        src={report.thumbnail}
                                        alt={report.title}
                                        width={400}
                                        height={250}
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100"
                                    />
                                ) : (
                                    <div class="w-full h-full bg-brand-void/80 flex items-center justify-center">
                                        <span class="text-brand-red/10 font-mono text-xl uppercase tracking-tighter">DATA_STREAM</span>
                                    </div>
                                )}
                                <div class="absolute inset-0 bg-gradient-to-r from-transparent to-brand-void/40"></div>
                            </div>

                            <!-- Content Section -->
                            <div class="p-6 flex-grow flex flex-col justify-center relative">
                                <div class="flex items-center gap-4 mb-4">
                                    <span class="font-mono text-[9px] text-brand-red tracking-[0.3em] font-bold">
                                        REPORT_{String(index + 1).padStart(2, '0')}
                                    </span>
                                    <div class="h-px w-8 bg-brand-text/10"></div>
                                    <time class="font-mono text-[9px] text-brand-muted/60 uppercase tracking-widest">
                                        {report.date}
                                    </time>
                                </div>
                                
                                <h4 class="text-xl font-black mb-3 group-hover:text-brand-red transition-colors leading-tight line-clamp-2 uppercase tracking-tight">
                                    {report.title}
                                </h4>
                                
                                <p class="text-sm text-brand-muted line-clamp-2 mb-4 font-light leading-relaxed">
                                    {report.blurb}
                                </p>
                                
                                <div class="mt-auto flex items-center gap-4">
                                    <span class="font-mono text-[10px] text-brand-red group-hover:translate-x-1 transition-transform">
                                        [ ACCESS_DATA ]
                                    </span>
                                    <div class="h-px flex-grow bg-brand-text/5 group-hover:bg-brand-red/20 transition-colors"></div>
                                </div>
                            </div>
                        </article>
                    </a>
                ))
            ) : (
                <div class="py-12 text-center text-brand-muted font-mono text-xs col-span-full uppercase tracking-widest border border-brand-text/5">
                    SIGNAL_LOST: FETCH_ERROR // blog.tibcert.org
                </div>
            )}
        </div>
    </div>
</section>
