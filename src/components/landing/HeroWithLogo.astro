    <div class="max-w-3xl mx-auto relative px-8 mb-12">
        <!-- Text Content Brackets -->
        <div
            class="absolute left-0 top-0 h-full w-px bg-gradient-to-b from-transparent via-brand-red/20 to-transparent"
        >
        </div>
        <div
            class="absolute right-0 top-0 h-full w-px bg-gradient-to-b from-transparent via-brand-red/20 to-transparent"
        >
        </div>

        <p
            class="text-xl md:text-2xl text-brand-muted leading-relaxed text-center"
        >
            Strengthening security and building technical excellence of Tibetan
            organizations through collaboration and knowledge sharing
        </p>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
            href="/contact"
            class="w-full sm:w-auto bg-brand-red hover:bg-[#d13d25]
text-white font-mono text-sm tracking-widest py-4 px-10 rounded-sm transition-all flex items-center
justify-center gap-3 group shadow-xl shadow-brand-red/20"
        >
            <span>[ REPORT_INCIDENT ]</span>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 group-hover:translate-x-1
transition-transform"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"
                ></path>
            </svg>
        </a>
        <a
            href="/blog"
            class="w-full sm:w-auto bg-brand-surface
border border-white/10 text-brand-text font-mono text-sm tracking-widest py-4 px-10 rounded-sm
transition-all flex items-center justify-center gap-2 hover:bg-white/5"
        >
            SEARCH_DATABASE
        </a>
    </div>
</section>
