---
import BackgroundGlow from "../common/BackgroundGlow.astro";
import TibetanPattern from "../common/TibetanPattern.astro";
---

<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden">
    <!-- Dynamic Background -->
    <div class="absolute inset-0 bg-brand-void z-0">
        <div
            class="absolute inset-0
bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)]
bg-[size:24px_24px]"
        >
        </div>

        <!-- Tibetan Pattern Accent -->
        <TibetanPattern
            class="absolute -right-20 -top-20 md:-right-32 md:-top-32 rotate-12"
            size="w-96 h-96 md:w-[600px] md:h-[600px]"
            color="var(--color-brand-maroon)"
            opacity="opacity-5 dark:opacity-10"
        />

        <div
            class="absolute left-0 right-0 top-0 -z-10
m-auto h-[310px] w-[310px] rounded-full bg-brand-red opacity-20 blur-[100px]"
        >
        </div>
    </div>
    <div class="container mx-auto px-4 relative z-10 text-center">
        <!-- Technical Label -->
        <div
            class="flex items-center justify-center gap-4 mb-8 animate-fade-in opacity-60"
        >
            <div class="h-px w-8 bg-brand-red/30"></div>
            <span
                class="font-mono text-[10px] tracking-[0.3em] uppercase text-brand-red/80"
                >System Connectivity: SECURE</span
            >
            <div class="h-px w-8 bg-brand-red/30"></div>
        </div>

        <div
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-sm bg-blue-500/5
border border-blue-500/20 text-blue-400 text-[10px] font-mono uppercase tracking-widest mb-10
animate-fade-in-up"
        >
            <span class="relative flex h-2 w-2">
                <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400
opacity-75"
                ></span>
                <span
                    class="relative inline-flex rounded-full h-2 w-2
bg-blue-500"
                ></span>
            </span> Official Cybersecurity Authority for the Tibetan Community
        </div>

        <!-- Official SVG Logo -->
        <div class="max-w-xl mx-auto mb-10 group relative">
            <!-- Scanline Overlay Effect -->
            <div
                class="absolute inset-0 z-20 pointer-events-none opacity-20 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_4px,3px_100%]"
            >
            </div>

            <svg
                id="logo"
                version="1.1"
                xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink"
                x="0px"
                y="0px"
                viewBox="0 0 402.1 75.2"
                class="w-full h-auto drop-shadow-[0_0_20px_rgba(239,72,44,0.1)] group-hover:drop-shadow-[0_0_40px_rgba(239,72,44,0.4)] transition-all duration-1000"
                xml:space="preserve"
            >
                <defs>
                    <linearGradient
                        id="shimmer"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="0%"
                    >
                        <stop offset="0%" stop-color="transparent"></stop>
                        <stop offset="45%" stop-color="transparent"></stop>
                        <stop offset="50%" stop-color="rgba(255,255,255,0.6)"
                        ></stop>
                        <stop offset="55%" stop-color="transparent"></stop>
                        <stop offset="100%" stop-color="transparent"></stop>
                        <animateTransform
                            attributeName="gradientTransform"
                            type="translate"
                            from="-1 0"
                            to="1 0"
                            dur="4s"
                            repeatCount="indefinite"
                            begin="3s"></animateTransform>
                    </linearGradient>

                    <mask id="shimmer-mask">
                        <rect
                            x="0"
                            y="0"
                            width="100%"
                            height="100%"
                            fill="url(#shimmer)"></rect>
                    </mask>

                    <mask id="logo-clip">
                        <use href="#main-logo-group" fill="white"></use>
                    </mask>
                </defs>

                <style type="text/css">
                    .st0 {
                        fill: white;
                        opacity: 0;
                        animation: flicker 0.8s cubic-bezier(0.4, 0, 0.2, 1)
                            forwards;
                    }

                    .st1 {
                        fill: #ef482c;
                        opacity: 0;
                        animation:
                            flicker 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards,
                            pulse-red-tech 3s ease-in-out infinite alternate;
                    }

                    .st2 {
                        fill: white;
                        opacity: 0;
                        animation: flicker 0.8s cubic-bezier(0.4, 0, 0.2, 1)
                            forwards;
                    }

                    .shimmer-layer {
                        fill: white;
                        opacity: 0;
                        mix-blend-mode: overlay;
                        animation: flicker 0.8s cubic-bezier(0.4, 0, 0.2, 1)
                            forwards;
                    }

                    @keyframes flicker {
                        0% {
                            opacity: 0;
                            transform: skewX(10deg) translateX(-10px);
                            filter: blur(2px);
                        }
                        5% {
                            opacity: 0.5;
                        }
                        10% {
                            opacity: 0;
                        }
                        15% {
                            opacity: 1;
                            transform: skewX(-5deg) translateX(5px);
                            filter: blur(0px);
                        }
                        20% {
                            opacity: 0.2;
                        }
                        25% {
                            opacity: 1;
                            transform: skewX(0deg) translateX(0px);
                        }
                        100% {
                            opacity: 0.9;
                        }
                    }

                    @keyframes pulse-red-tech {
                        0% {
                            filter: brightness(1)
                                drop-shadow(0 0 5px rgba(239, 72, 44, 0.4));
                        }
                        100% {
                            filter: brightness(1.6)
                                drop-shadow(0 0 20px rgba(239, 72, 44, 1));
                        }
                    }

                    /* Staggered delays for organic reveal */
                    .delay-1 {
                        animation-delay: 0.1s;
                    }
                    .delay-2 {
                        animation-delay: 0.3s;
                    }
                    .delay-3 {
                        animation-delay: 0.5s;
                    }
                    .delay-4 {
                        animation-delay: 0.7s;
                    }
                    .delay-5 {
                        animation-delay: 0.9s;
                    }
                </style>

                <g id="main-logo-group" class="logo-group">
                    <!-- Main Logo Paths -->
                    <path
