---
import BackgroundGlow from "../common/BackgroundGlow.astro";
import SectionDivider from "../common/SectionDivider.astro";
const services = [
    {
        title: "Incident Response",
        description:
            "Direct assistance for digital attacks: malware removal, account recovery, and forensic analysis.",
        image: "/images/landing/incident-response.png",
        span: "lg:col-span-2 lg:row-span-1",
        type: "image",
    },
    {
        title: "Security Training",
        description: "Custom workshops and digital hygiene education.",
        image: "/images/landing/training.png",
        span: "lg:col-span-1 lg:row-span-1",
        type: "image",
    },
    {
        title: "Infrastructure Audits",
        description: "Deep-dive security assessments for your systems.",
        image: "/images/landing/audits.png",
        span: "lg:col-span-1 lg:row-span-1",
        type: "image",
    },
    {
        title: "Priority Response",
        description:
            "24/7 helpdesk with priority incident handling and technical assistance.",
        icon: "🆘",
        span: "lg:col-span-1 lg:row-span-1",
        color: "brand-red",
        type: "icon",
    },
    {
        title: "Capacity Building",
        description:
            "Invitations to specialized trainings on digital forensics and defense.",
        icon: "🎓",
        span: "lg:col-span-1 lg:row-span-1",
        color: "brand-amber",
        type: "icon",
    },
    {
        title: "Threat Intelligence",
        description:
            "Monitoring targeted attacks to provide real-time alerts and actionable defense strategies for the entire community.",
        image: "/images/landing/threat-intel.png",
        span: "lg:col-span-2 lg:row-span-1",
        type: "image",
    },
];
---

<section class="py-24 bg-brand-void relative overflow-hidden reveal">
    <!-- Sophisticated Background Accents -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-red/5 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-brand-amber/5 blur-[100px] rounded-full translate-y-1/2 -translate-x-1/2"></div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mb-20 reveal relative">
            <!-- Technical Brackets -->
            <div class="absolute -top-8 -left-8 w-12 h-12 border-t border-l border-brand-red/20 opacity-60"></div>
            
            <span class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-4 block uppercase opacity-60">SERVICE_CATALOG // OPERATIONAL_SCOPE</span>
            <h2 class="text-4xl md:text-6xl font-black mb-6 text-brand-text leading-tight uppercase tracking-tight italic">
                Our <span class="text-brand-red">Core</span> Services
            </h2>
            <SectionDivider class="text-brand-red w-48 mb-8" />
            <p class="text-brand-muted text-xl leading-relaxed max-w-2xl">
                Specialized cybersecurity support tailored for organization-level resilience and community protection.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-text/5 border border-brand-text/5">
            {
                services.map((service, index) => (
                    <div class="group relative py-16 px-8 bg-brand-void hover:bg-brand-red/[0.02] transition-all duration-500 overflow-hidden">
                        <!-- Technical Background Pattern -->
                        <div class="absolute top-0 right-0 w-32 h-32 opacity-0 group-hover:opacity-10 transition-opacity duration-700 pointer-events-none">
                            <div class="absolute top-4 right-4 w-12 h-px bg-brand-red"></div>
                            <div class="absolute top-4 right-4 h-12 w-px bg-brand-red"></div>
                        </div>

                        <!-- Scanline and Glow -->
                        <div class="absolute inset-0 bg-[linear-gradient(to_bottom,transparent_0%,rgba(239,72,44,0.05)_50%,transparent_100%)] bg-[length:100%_200%] bg-[position:0_-100%] group-hover:bg-[position:0_100%] transition-all duration-[1500ms] pointer-events-none"></div>
                        
                        <div class="relative z-10 flex flex-col gap-6 h-full">
                            <!-- Technical Header -->
                            <div class="flex flex-col gap-2">
                                <div class="flex items-center gap-3">
                                    <span class="font-mono text-[10px] text-brand-red tracking-[0.3em] font-bold">
                                        ID_{String(index + 1).padStart(2, '0')}
                                    </span>
                                    <div class="h-px flex-grow bg-brand-text/10 group-hover:bg-brand-red/30 transition-colors"></div>
                                </div>
                                <h3 class="text-2xl font-black text-brand-red group-hover:text-brand-red transition-colors duration-500 uppercase tracking-tight">
                                    {service.title}
                                </h3>
                            </div>

                            <!-- Description with Monospace Metadata -->
                            <div class="flex-grow flex flex-col gap-4">
                                <p class="text-brand-muted group-hover:text-brand-text transition-colors duration-500 text-base leading-relaxed font-light">
                                    {service.description}
                                </p>
                                <div class="mt-auto pt-4 border-t border-brand-text/5 flex items-center justify-between">
                                    <span class="font-mono text-[9px] uppercase text-brand-muted/40 tracking-widest">Protocol_{service.title.split(' ')[0]}</span>
                                    <span class="h-1.5 w-1.5 bg-brand-red/40 rounded-full animate-pulse"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Card Notches -->
                        <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                        <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-brand-text/10 group-hover:border-brand-red/40 transition-colors"></div>
                    </div>
                ))
            }
        </div>

        <div class="mt-20 flex justify-center">
            <a 
                href="/services" 
                class="inline-flex items-center gap-6 text-brand-muted hover:text-brand-red font-mono text-sm tracking-[0.4em] uppercase transition-all group"
            >
                <span class="opacity-0 group-hover:opacity-100 -translate-x-4 group-hover:translate-x-0 transition-all">&gt;&gt;</span>
                ACCESS_FULL_CATALOG
                <span class="h-px w-12 bg-brand-text/10 group-hover:w-20 group-hover:bg-brand-red transition-all"></span>
            </a>
        </div>
    </div>
</section>
