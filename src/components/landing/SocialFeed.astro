---
import BackgroundGlow from "../common/BackgroundGlow.astro";
import SectionDivider from "../common/SectionDivider.astro";
import { getLatestSocialPosts } from "../../utils/social-data";

const posts = await getLatestSocialPosts();

const platformIcons = {
    facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>`,
    instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`
};
---

<section id="social-hub" class="py-24 bg-brand-void relative overflow-hidden reveal">
    <!-- Technical Background -->
    <BackgroundGlow 
        color="fill-brand-red" 
        size="w-[600px] h-[600px]" 
        opacity="opacity-5" 
        class="top-0 -right-48" 
    />
    
    <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16 relative">
            <div class="max-w-2xl">
                <span class="font-mono text-[10px] text-brand-red tracking-[0.4em] mb-4 block uppercase opacity-60">SOCIAL_INTELLIGENCE // ANALYTICS</span>
                <h3 class="text-3xl md:text-5xl font-black text-brand-text mb-4 uppercase tracking-tight italic">
                    Live <span class="text-brand-red">Insights</span>
                </h3>
                <SectionDivider class="text-brand-red w-48 mb-6" />
                <p class="text-lg text-brand-muted leading-relaxed">
                    Analyzing community engagement and real-time security conversations across our social infrastructure.
                </p>
            </div>
            <div class="flex items-center gap-4 pb-2 border-b-2 border-brand-red/10">
                <span class="flex h-2 w-2 relative">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-red opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-red"></span>
                </span>
                <span class="font-mono text-[10px] text-brand-text uppercase tracking-widest">REALTIME_SCANNING</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {posts.map((post) => (
                <a 
                    href={post.link} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="group relative bg-brand-surface/30 border border-brand-text/10 p-6 flex flex-col h-full hover:border-brand-red/30 transition-all duration-500 overflow-hidden"
                >
                    <!-- Animated Hover Background -->
                    <div class="absolute inset-0 bg-gradient-to-br from-brand-red/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

                    <!-- Platform Header -->
                    <div class="flex items-center justify-between mb-6 relative z-10">
                        <div class="flex items-center gap-2">
                            <div class:list={[
                                "w-6 h-6 rounded-sm flex items-center justify-center",
                                post.platform === 'facebook' ? "text-[#1877F2] bg-[#1877F2]/10" : "text-[#E4405F] bg-[#E4405F]/10"
                            ]} set:html={platformIcons[post.platform]}>
                            </div>
                            <span class="font-mono text-[9px] text-brand-text uppercase tracking-[0.2em]">{post.platform}</span>
                        </div>
                        <span class="font-mono text-[9px] text-brand-muted/40 uppercase tracking-widest">{post.date}</span>
                    </div>

                    <!-- Media if available -->
                    {post.imageUrl && (
                        <div class="mb-4 aspect-video overflow-hidden border border-brand-text/5 relative z-10">
                            <img src={post.imageUrl} alt="Social media content" class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 scale-105 group-hover:scale-100" />
                        </div>
                    )}

                    <!-- Content -->
                    <p class="text-sm text-brand-muted font-light leading-relaxed mb-6 line-clamp-4 relative z-10 group-hover:text-brand-text transition-colors">
                        {post.content}
                    </p>

                    <!-- Metrics / Footer -->
                    <div class="mt-auto pt-4 border-t border-brand-text/5 flex items-center gap-4 relative z-10">
                        <div class="flex items-center gap-1.5 group/metric">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-red/40 group-hover/metric:text-brand-red transition-colors"><path d="M7 10v12"></path><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"></path></svg>
                            <span class="font-mono text-[9px] text-brand-muted">{post.metrics.likes}</span>
                        </div>
                        <div class="flex items-center gap-1.5 group/metric">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-red/40 group-hover/metric:text-brand-red transition-colors"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                            <span class="font-mono text-[9px] text-brand-muted">{post.metrics.comments}</span>
                        </div>
                        {post.metrics.shares !== undefined && (
                            <div class="flex items-center gap-1.5 group/metric">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-red/40 group-hover/metric:text-brand-red transition-colors"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
                                <span class="font-mono text-[9px] text-brand-muted">{post.metrics.shares}</span>
                            </div>
                        )}
                        <div class="ml-auto w-4 h-4 text-brand-red opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-500">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                        </div>
                    </div>

                    <!-- Corner Accents -->
                    <div class="absolute top-0 right-0 w-8 h-8 pointer-events-none overflow-hidden">
                        <div class="absolute top-0 right-0 w-[141%] h-px bg-brand-red/20 rotate-45 translate-x-1/2 -translate-y-1/2 group-hover:bg-brand-red transition-colors"></div>
                    </div>
                </a>
            ))}
        </div>

        <div class="mt-16 flex justify-center">
            <div class="inline-flex items-center gap-8 px-8 py-3 bg-brand-surface/20 border border-brand-text/5 rounded-full backdrop-blur-sm">
                <a href="https://facebook.com/tibcert" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] text-brand-muted hover:text-brand-red transition-colors uppercase tracking-[0.2em]">Follow_FB</a>
                <div class="w-px h-4 bg-brand-text/10"></div>
                <a href="https://instagram.com/tibcert" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] text-brand-muted hover:text-brand-red transition-colors uppercase tracking-[0.2em]">Follow_IG</a>
                <div class="w-px h-4 bg-brand-text/10"></div>
                <a href="https://x.com/tibcert" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] text-brand-muted hover:text-brand-red transition-colors uppercase tracking-[0.2em]">Follow_X</a>
                <div class="w-px h-4 bg-brand-text/10"></div>
                <a href="https://github.com/tibcert" target="_blank" rel="noopener noreferrer" class="font-mono text-[10px] text-brand-muted hover:text-brand-red transition-colors uppercase tracking-[0.2em]">Follow_GH</a>
            </div>
        </div>
    </div>
</section>
